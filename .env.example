# Firebase production project for EPSOLUCOES.
# Create this project in Firebase and enable Authentication (Google) and Firestore.
VITE_FIREBASE_API_KEY="your_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project"
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:0000000000000000000000"
VITE_FIREBASE_MEASUREMENT_ID=""

# Use "(default)" for the default Firestore database, or the custom database id if you create one.
VITE_FIREBASE_DATABASE_ID="(default)"

# Cloudflare Worker endpoint for OS attachments stored in R2.
VITE_UPLOADS_API_URL="https://erp-epsolucoes-attachments.epsolucoesemimpressoras.workers.dev"

# Optional: enables AI diagnosis suggestions in service orders.
VITE_GEMINI_API_KEY=""

# Public URL after deployment, for links such as order tracking.
VITE_APP_URL="https://erp-epsolucoes.pages.dev"
